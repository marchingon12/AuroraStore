<resources>

    <!-- Base application theme. -->
    <style name="BaseTheme" parent="Theme.Material3.DynamicColors.DayNight.NoActionBar">
        <item name="colorShimmer">@color/colorShimmer</item>
        <item name="chipStyle">@style/Widget.Material3.Chip.Filter</item>
        <item name="preferenceTheme">@style/AppTheme.PreferenceThemeOverlay</item>
    </style>

    <style name="AppTheme" parent="BaseTheme">
        <item name="chipStyle">@style/Widget.Material3.Chip.Filter</item>
        <item name="preferenceTheme">@style/AppTheme.PreferenceThemeOverlay</item>
        <item name="android:navigationBarColor">?attr/colorSurface</item>
        <item name="android:statusBarColor">?attr/colorSurface</item>
    </style>

    <style name="AppTheme.Translucent" parent="BaseTheme">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowAnimationStyle">@android:style/Animation</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>

    <!-- Custom Themes -->
    <style name="AppTheme.Light" parent="Theme.Material3.DynamicColors.Light.NoActionBar">
        <item name="colorShimmer">@color/colorShimmer</item>
    </style>

    <style name="AppTheme.Dark" parent="Theme.Material3.DynamicColors.Dark.NoActionBar">
        <item name="colorShimmer">@color/colorDarkShimmer</item>
    </style>

    <style name="AppTheme.DarkX" parent="AppTheme.Dark">
        <item name="colorSurface">@color/colorDarkXPrimary</item>
        <item name="colorSurfaceContainer">@color/colorDarkXBackground</item>
        <item name="android:windowBackground">@color/colorDarkXWindowBackground</item>
        <item name="android:colorBackground">@color/colorDarkXBackground</item>
        <item name="colorBackgroundFloating">@color/colorDarkXBackground</item>
        <item name="android:navigationBarColor">@color/colorDarkXPrimary</item>
        <item name="colorShimmer">@color/colorDarkXShimmer</item>
    </style>

    <style name="AppTheme.Darkord" parent="AppTheme.Dark">
        <item name="colorSurface">@color/colorDarkordPrimary</item>
        <item name="colorSurfaceContainer">@color/colorDarkordBackground</item>
        <item name="android:windowBackground">@color/colorDarkordWindowBackground</item>
        <item name="android:colorBackground">@color/colorDarkordBackground</item>
        <item name="colorBackgroundFloating">@color/colorDarkordBackground</item>
        <item name="android:navigationBarColor">@color/colorDarkordPrimary</item>
        <item name="colorShimmer">@color/colorDarkordShimmer</item>
    </style>

    <style name="AppTheme.Black" parent="AppTheme.Dark">
        <item name="colorSurface">@color/colorBlack</item>
        <item name="colorSurfaceContainer">@color/colorBlack</item>
        <item name="android:windowBackground">@color/colorBlack</item>
        <item name="android:colorBackground">@color/colorBlack</item>
        <item name="colorBackgroundFloating">@color/colorBlack</item>
        <item name="android:navigationBarColor">@color/colorBlack</item>
        <item name="colorShimmer">@color/colorShimmerBlack</item>
    </style>

    <style name="AppTheme.PreferenceThemeOverlay" parent="@style/PreferenceThemeOverlay">
        <item name="android:layout">@layout/fragment_setting</item>
        <item name="switchPreferenceCompatStyle">@style/AppTheme.SwitchPreference</item>
    </style>

    <style name="AppTheme.SwitchPreference" parent="@style/Preference.SwitchPreferenceCompat.Material">
        <item name="widgetLayout">@layout/preference_material_switch</item>
    </style>
</resources>
